    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE incidents SET muc_do_khan_cap = \nCASE \n  WHEN TRIM('{{ $json.level }}') = '1' THEN 'Khẩn cấp'\n  WHEN TRIM('{{ $json.level }}') = '2' THEN 'Ưu tiên'\n  WHEN TRIM('{{ $json.level }}') = '3' THEN 'Bình thường'\n  ELSE 'Bình thường'\nEND\nWHERE id = {{ $json.incident_id }};\n\nSELECT \n  TRIM('{{ $json.level }}') as level_ai, -- Lấy luôn giá trị level vào đây\n  p.ma_phong, t.ho_ten, t.email, i.loai_su_co, i.mo_ta \nFROM incidents i\nJOIN rooms p ON i.room_id = p.id\nJOIN tenants t ON i.tenant_id = t.id\nWHERE i.id = {{ $json.incident_id }};\n",
        "options": {}
      },
