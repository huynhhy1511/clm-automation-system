        "jsonBody": "={\n  \"model\": \"meta-llama/llama-4-scout-17b-16e-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Đây là ảnh chụp công tơ điện. Hãy nhìn vào ô hiển thị chỉ số chính (thường nằm cạnh chữ kWh) và cho tôi biết con số hiện tại là bao nhiêu. Trả về kết quả dưới dạng JSON: {\\\"chiSoDien\\\": 123}\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"data:image/jpeg;base64,{{ $json.imageBase64 }}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}\n",
