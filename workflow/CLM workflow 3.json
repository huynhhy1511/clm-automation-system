        "jsCode": "const fileBuffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst pdfBase64 = fileBuffer.toString('base64');\nconst info = $node[\"2. Tính Toán & VietQR\"].json;\n\nreturn {\n  json: { ...info, pdfBase64 },\n  binary: { data: await this.helpers.prepareBinaryData(fileBuffer, `HoaDon_P${info.phong}.pdf`, 'application/pdf') }\n};"
      },
