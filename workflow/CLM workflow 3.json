    {
      "parameters": {
        "jsCode": "\ntry {\n  // Lấy dữ liệu từ Groq (Nằm trong choices[0].message.content)\n  const groqOutput = $json.choices[0].message.content;\n  \n  let chiSoMoi = 0;\n  try {\n    const jsonMatch = groqOutput.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) {\n      const parsed = JSON.parse(jsonMatch[0]);\n      chiSoMoi = parsed.chiSoDien || 0;\n    } else {\n      const match = groqOutput.match(/\\d+/);\n      chiSoMoi = match ? Number(match[0]) : 0;\n    }\n  } catch (e) {\n    const match = groqOutput.match(/\\d+/);\n    chiSoMoi = match ? Number(match[0]) : 0;\n  }\n  \n  const caption = $('gửi ảnh Telegram').item.json.message.caption || '';\n  // Thay đoạn regex cũ bằng đoạn này để lấy cả chữ cái (ví dụ: P101)\n  const matchPhong = caption.match(/(?:#|Phòng\\s*)?([A-Z]*\\d{3,4})/i);\n  const phong = matchPhong ? matchPhong[1] : '???';\n\n  \n  if (phong === '???') throw new Error(\"Lỗi: Bạn chưa ghi mã phòng ở phần Caption (ví dụ: P101)\");\n\n  return {\n    json: {\n      phong: phong,\n      chiSoDienMoi: chiSoMoi,\n      nguon: \"AI_GROQ_ADMIN\",\n      ai_raw: groqOutput\n    }\n  };\n} catch (error) {\n  throw new Error(\"Lỗi xử lý dữ liệu AI Groq: \" + error.message);\n}\n"
      },
