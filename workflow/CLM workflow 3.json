      "parameters": {
        "jsCode": "try {\n  const ADMIN_TELEGRAM_ID = 6126814953;\n  const senderId = $('gửi ảnh Telegram').item.json.message.from.id;\n  if (senderId !== ADMIN_TELEGRAM_ID) throw new Error(\"Cảnh báo: Bạn không có quyền sử dụng Bot!\");\n  const ocrText = $json.ParsedResults[0].ParsedText;\n  const caption = $('gửi ảnh Telegram').item.json.message.caption || '';\n  const matchPhong = caption.match(/(?:P|#|Phòng\\s*)(\\d{3,4})/i);\n  const phong = matchPhong ? matchPhong[1] : '???';\n  if (phong === '???') throw new Error(\"Lỗi: Quên ghi mã phòng ở phần Caption rồi!\");\n  const numbers = ocrText.match(/\\d+/g);\n  let chiSoMoi = 0;\n  if (numbers && numbers.length > 0) chiSoMoi = Math.max(...numbers.map(Number)); \n  return {\n    json: {\n      phong: phong,\n      chiSoDienMoi: chiSoMoi,\n      nguon: \"AI_OCR_ADMIN\"\n    }\n  };\n} catch (error) {\n  throw new Error(error.message);\n}"
