      "id": "3d0fcd8e-cc86-4810-bc94-d92a71de916a",
      "name": "1. Cài đặt Đơn giá",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        -288,
        1264
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Hàm lấy dữ liệu cực mạnh (Tìm mọi ngõ ngách)\nconst getInput = () => {\n  const raw = $input.item.json;\n  return raw.body?.body || raw.body || raw;\n};\n\n// 2. Lấy cấu hình giá (Đảm bảo lấy đúng từ node Cài đặt)\nconst getConfig = () => {\n  try {\n    return $node[\"1. Cài đặt Đơn giá\"].json;\n  } catch (e) {\n    return { gia_dien: 3500, gia_nuoc_khoan: 100000, phi_dv: 50000 };\n  }\n};\n\nconst d = getInput();\nconst config = getConfig();\n\n// 3. Ép kiểu về số (Number) để tránh lỗi NaN\nconst dienCu = Number(d.chiSoDienCu || 0);\nconst dienMoi = Number(d.chiSoDienMoi || 0);\nconst giaDien = Number(config.gia_dien || 3500);\nconst tienPhong = Number(d.tienPhong || d.tongTien || 0); // Ưu tiên tiền phòng riêng, nếu ko lấy tổng\nconst giaNuocDV = Number(config.gia_nuoc_khoan || 0) + Number(config.phi_dv || 0);\n\n// 4. Tính toán chi tiết\nconst val_dien = (dienMoi - dienCu) * giaDien;\nconst val_tong = tienPhong + val_dien + giaNuocDV;\n\n// 5. Định dạng tiền tệ VNĐ\nconst fmt = (v) => new Intl.NumberFormat('vi-VN').format(v) + ' đ';\n\n// 6. Trả về kết quả (Full Option)\nreturn {\n  json: {\n    ...d,\n    // Số thô để lưu Database (Node 6)\n    val_dien,\n    val_tong,\n    val_nuoc_dv: giaNuocDV,\n    val_phong: tienPhong,\n    // Link QR\n    qrUrl: `https://img.vietqr.io/image/MB-0905881525-compact2.png?amount=${val_tong}&addInfo=ThanhToan_P${d.phong}&accountName=HUYNH%20NGOC%20HUY`,\n    // Chữ để hiện lên PDF (Node 3)\n    txt_phong: fmt(tienPhong),\n    txt_dien: fmt(val_dien),\n    txt_nuoc_dv: fmt(giaNuocDV),\n    txt_tong: fmt(val_tong),\n    dien_tieu_thu: dienMoi - dienCu\n  }\n};"
      },
      "id": "9263117f-fa6c-44d5-87eb-865788499c60",
      "name": "2. Tính Toán & VietQR",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -32,
        1264
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.item.json;\nconst today = new Date();\n\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n  body { font-family: \"Arial\", sans-serif; line-height: 1.6; color: #333; }\n  .header { border-bottom: 2px solid #1e40af; padding-bottom: 10px; margin-bottom: 20px; }\n  table { width: 100%; border-collapse: collapse; margin: 20px 0; }\n  th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }\n  th { background-color: #f8fafc; color: #1e40af; }\n  .total-row { font-size: 20px; font-weight: bold; color: #dc2626; text-align: right; margin-top: 20px; }\n</style>\n</head>\n<body>\n  <div class=\"header\">\n    <p style=\"float: right;\">Ngày lập: ${today.getDate()}/${today.getMonth()+1}/${today.getFullYear()}</p>\n    <h2 style=\"color: #1e40af; margin: 0;\">HÓA ĐƠN TIỀN NHÀ - P.${d.phong}</h2>\n  </div>\n\n  <p><b>Khách hàng:</b> ${d.hoTen || 'Quý khách'}</p>\n\n  <table style=\"width:100%; border-collapse: collapse;\">\n  <thead>\n    <tr style=\"background-color: #f1f5f9;\">\n      <th style=\"padding:10px; border:1px solid #ddd;\">Hạng mục</th>\n      <th style=\"padding:10px; border:1px solid #ddd;\">Chỉ số / Số lượng</th>\n      <th style=\"padding:10px; border:1px solid #ddd;\">Thành tiền</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td style=\"padding:10px; border:1px solid #ddd;\">Tiền phòng</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:center;\">1 tháng</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:right;\"><b>${d.txt_phong}</b></td>\n    </tr>\n    <tr>\n      <td style=\"padding:10px; border:1px solid #ddd;\">Tiền điện</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:center;\">${d.chiSoDienCu} ➔ ${d.chiSoDienMoi}</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:right;\"><b>${d.txt_dien}</b></td>\n    </tr>\n    <tr>\n      <td style=\"padding:10px; border:1px solid #ddd;\">Nước & Dịch vụ</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:center;\">Khoán</td>\n      <td style=\"padding:10px; border:1px solid #ddd; text-align:right;\"><b>${d.txt_nuoc_dv}</b></td>\n    </tr>\n  </tbody>\n</table>\n\n<div style=\"text-align:right; margin-top:20px; font-size:20px;\">\n  <span style=\"color:#64748b;\">TỔNG THANH TOÁN:</span> <b style=\"color:#dc2626;\">${d.txt_tong}</b>\n</div>\n\n  <div style=\"text-align: center; margin-top: 30px;\">\n    <p><i>Vui lòng quét mã QR bên dưới để thanh toán</i></p>\n    <img src=\"${d.qrUrl}\" width=\"220\" style=\"border: 1px solid #ddd; padding: 10px; border-radius: 8px;\">\n  </div>\n</body>\n</html>\n`;\n\nreturn {\n  json: d,\n  binary: {\n    indexHtml: await this.helpers.prepareBinaryData(Buffer.from(html), 'index.html', 'text/html')\n  }\n};"
      },
